# 後端服務埠號
PORT=3008

# 前端來源(CORS 白名單)
WEB_ORIGIN=http://localhost:5173

# PostgreSQL 連線設定
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=jp_word

# 開發時可設 true 讓 TypeORM 自動同步 schema(正式環境請用 migration,設為 false)
DB_SYNCHRONIZE=true

# ── 以下為「部署」用(本機開發可忽略)─────────────────
# 執行環境:production 時後端會一併托管前端 build 產物
# NODE_ENV=production
# 雲端平台提供的單一連線字串;有值時優先於上面的個別 DB_ 欄位
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# 代管 Postgres(如 Neon)需要 SSL 時設 true;Zeabur 內網 Postgres 通常免
# DB_SSL=false
# 為 true 時,啟動若資料庫是空的就自動灌種子(部署 Demo 方便用)
# AUTO_SEED=true
