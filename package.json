{
  "name": "jp-word",
  "version": "0.0.1",
  "private": true,
  "description": "日文單字射擊遊戲 monorepo",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter \"./apps/*\" build",
    "build:deploy": "pnpm --filter @jp-word/web build",
    "start": "pnpm --filter @jp-word/api start",
    "typecheck": "pnpm --recursive typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
